# Copy this file to .env for local development.
# On Railway, set these as Variables in the service settings instead —
# do NOT commit a real .env file to git.

# Required: your Discord bot token (Discord Developer Portal > Bot > Reset Token)
TOKEN=

# Optional: powers the AI chat/AI-command features (https://console.groq.com/keys)
GROQ_API_KEY=

# Optional: powers image search commands (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Optional: powers GIF/meme commands (https://developers.giphy.com/)
GIPHY_API_KEY=
